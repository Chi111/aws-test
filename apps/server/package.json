{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "db:seed": "tsx src/seed.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@github-profile-sam/db": "workspace:*",
    "@github-profile-sam/env": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@github-profile-sam/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
